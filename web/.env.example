# Base URL of the RenovateConnect API for SSR/server-side fetches (never exposed).
# Dev: http://localhost:3000  ·  Prod: https://api.renovateconnect.app
API_BASE_URL=http://localhost:3000

# Same API, but for the BROWSER (the estimator uploads directly so the backend
# sees the real client IP for per-IP rate limiting). Must be on the API's
# WEB_ORIGINS allowlist. NEXT_PUBLIC_ is inlined into the client bundle.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Apple Associated Domains appID = <TeamID>.<BundleID>, e.g. ABCDE12345.app.renovateconnect
# Served in /.well-known/apple-app-site-association so universal links open the app.
IOS_APP_ID=TEAMID.app.renovateconnect

# App Store listing (for "Get the app" CTAs + smart app banner).
APP_STORE_URL=https://apps.apple.com/app/renovateconnect/idXXXXXXXXXX
APPLE_APP_STORE_ID=XXXXXXXXXX
