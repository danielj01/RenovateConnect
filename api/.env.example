# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/renovate_connect

# Auth
JWT_SECRET=change-me-in-production

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# In-app deposit economics (Option A). Deposit = DEPOSIT_PERCENT of the quote
# midpoint, floored at DEPOSIT_MIN_CENTS; commission = COMMISSION_BPS of the
# deposit, charged on top as the Stripe application fee.
DEPOSIT_PERCENT=10
DEPOSIT_MIN_CENTS=5000
COMMISSION_BPS=800
# "Pro" contractor subscription tiers: monthly price (cents) + free-trial length.
# sponsored = Sponsored search slot; insights = sponsored + aggregated market data.
PRO_PRICE_CENTS=500
INSIGHTS_PRICE_CENTS=1000
PRO_TRIAL_DAYS=90
# Base URL Stripe-hosted Checkout / Connect onboarding redirects back to.
APP_BASE_URL=https://renovateconnect.app

# Push notifications (Apple Push Notification service, token-based auth)
# Leave blank to disable push — the server will no-op gracefully.
APNS_KEY_ID=...            # 10-char Key ID from the AuthKey_XXXX.p8
APNS_TEAM_ID=...           # Apple Developer Team ID
APNS_BUNDLE_ID=com.yourco.RenovateConnect  # app bundle id (apns-topic)
APNS_KEY=                  # contents of AuthKey_XXXX.p8 (use \n for newlines)
APNS_PRODUCTION=false      # true = api.push.apple.com, false = sandbox

# AWS S3 (photo storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=renovate-connect-uploads

# Error tracking (Sentry). Leave blank to disable — nothing is sent without it.
# Set the DSN in production to capture unhandled server errors.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Internal/ops endpoints (e.g. POST /internal/sweep driven by an external cron).
# Leave blank to disable them entirely. Set to a long random secret to enable;
# callers must send it in the `x-internal-key` header.
INTERNAL_API_KEY=

# Web / CORS. Comma-separated browser origins allowed to call the API (the
# native iOS app sends no Origin and is always allowed). Add the web front door.
WEB_ORIGINS=http://localhost:3000,https://renovateconnect.app

# Max guest (unauthenticated) AI estimates per IP per hour — protects the open
# Claude-backed endpoint from cost/DoS abuse.
GUEST_ESTIMATE_MAX=8

# Max saved-estimate "share" writes per IP per hour (the web → app handoff).
SHARE_ESTIMATE_MAX=20

# Rate limiting (per 15-minute window). RATE_LIMIT_MAX is the baseline for the
# whole API (keyed per-user when authed, per-IP otherwise). AUTH_RATE_LIMIT_MAX
# is the strict cap on login/register/Apple to blunt brute-force.
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Server
PORT=3000
NODE_ENV=development
