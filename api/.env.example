# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/renovate_connect

# Auth
JWT_SECRET=change-me-in-production

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# In-app deposit economics (Option A). Deposit = DEPOSIT_PERCENT of the quote
# midpoint, floored at DEPOSIT_MIN_CENTS; commission = COMMISSION_BPS of the
# deposit, charged on top as the Stripe application fee.
DEPOSIT_PERCENT=10
DEPOSIT_MIN_CENTS=5000
COMMISSION_BPS=800
# Listing subscription: contractors pay this (cents/month) to be publicly
# listed after their free first month (FREE_LISTING_DAYS, stamped at first
# admin approval). Includes the Insights dashboard.
PRO_PRICE_CENTS=1000
FREE_LISTING_DAYS=30
# Boost: one-time charge (cents) for BOOST_DURATION_DAYS in the labeled slot
# above organic search. At most BOOST_CITY_CAP businesses per city can hold an
# active boost at once (first-come).
BOOST_PRICE_CENTS=500
BOOST_DURATION_DAYS=7
BOOST_CITY_CAP=3
# Base URL Stripe-hosted Checkout / Connect onboarding redirects back to.
APP_BASE_URL=https://renovateconnect.app

# Push notifications (Apple Push Notification service, token-based auth)
# Leave blank to disable push — the server will no-op gracefully.
APNS_KEY_ID=...            # 10-char Key ID from the AuthKey_XXXX.p8
APNS_TEAM_ID=...           # Apple Developer Team ID
APNS_BUNDLE_ID=app.renovateconnect  # app bundle id (apns-topic) — must match Xcode
APNS_KEY=                  # contents of AuthKey_XXXX.p8 (use \n for newlines)
APNS_PRODUCTION=false      # true = api.push.apple.com, false = sandbox

# Social sign-in.
# GOOGLE_CLIENT_IDS: comma-separated OAuth client ids accepted as the ID-token
# audience (at minimum the iOS client id from Google Cloud Console). Leave
# blank to disable Google sign-in (the endpoint returns 503).
GOOGLE_CLIENT_IDS=
# APPLE_BUNDLE_ID: audience for Sign in with Apple tokens. Defaults to
# APNS_BUNDLE_ID when unset; both should be the app's bundle id.
APPLE_BUNDLE_ID=

# AWS S3 (photo storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=renovate-connect-uploads

# Error tracking (Sentry). Leave blank to disable — nothing is sent without it.
# Set the DSN in production to capture unhandled server errors.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0

# Transactional email (SendGrid) — powers email verification + password reset.
# Leave SENDGRID_API_KEY or EMAIL_FROM blank to disable sending: in dev/CI/test
# the verify/reset endpoints return the code as `devCode` in the response so the
# flow is testable without email. In production BOTH must be set (and never
# returns devCode). EMAIL_FROM must be on a SendGrid-authenticated domain.
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@renovateconnect.app
EMAIL_FROM_NAME=RenovateConnect

# Internal/ops endpoints (e.g. POST /internal/sweep driven by an external cron).
# Leave blank to disable them entirely. Set to a long random secret to enable;
# callers must send it in the `x-internal-key` header.
INTERNAL_API_KEY=

# Web / CORS. Comma-separated browser origins allowed to call the API (the
# native iOS app sends no Origin and is always allowed). Add the web front door.
WEB_ORIGINS=http://localhost:3000,https://renovateconnect.app

# Max guest (unauthenticated) AI estimates per IP per hour — protects the open
# Claude-backed endpoint from cost/DoS abuse.
GUEST_ESTIMATE_MAX=8

# Max saved-estimate "share" writes per IP per hour (the web → app handoff).
SHARE_ESTIMATE_MAX=20

# Rate limiting (per 15-minute window). RATE_LIMIT_MAX is the baseline for the
# whole API (keyed per-user when authed, per-IP otherwise). AUTH_RATE_LIMIT_MAX
# is the strict cap on login/register/Apple to blunt brute-force.
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20

# Server
PORT=3000
NODE_ENV=development

# Stable hostname for locally-stored uploads (dev). Wins over the request-
# derived host so an old Mac LAN IP doesn't end up baked into image URLs
# in the DB. Prefer your Mac's mDNS name over a raw IP so it survives WiFi
# changes — get it with `scutil --get LocalHostName` and append ".local",
# e.g. http://Daniels-MacBook-Air-204.local:3000. In prod, set this to your
# public API URL (or use S3, which bypasses this code path entirely).
PUBLIC_BASE_URL=

# Cost-tier thresholds (dollars). A contractor's typical project midpoint <= LOW
# is "$", >= HIGH is "$$$", in between is "$$". Tune to your market.
COST_TIER_LOW_MAX=15000
COST_TIER_HIGH_MIN=50000
