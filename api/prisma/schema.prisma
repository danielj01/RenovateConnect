generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  BUSINESS
  ADMIN
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  DECLINED
  CANCELLED
}

enum ActivityType {
  LEAD
  MESSAGE
  APPOINTMENT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(CLIENT)
  name         String
  phone        String?
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Push notifications
  pushEnabled  Boolean   @default(true)

  business     Business?
  sentMessages     Message[]   @relation("SentMessages")
  conversations    Conversation[] @relation("ClientConversations")
  estimations      Estimation[]
  deviceTokens     DeviceToken[]
  favorites        Favorite[]
  appointments     Appointment[]  @relation("ClientAppointments")
  activities       Activity[]
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("ios")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Business {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName     String
  description     String
  logoUrl         String?
  website         String?
  licenseNumber   String?
  yearsInBusiness Int       @default(0)

  // Location
  address         String?
  city            String
  state           String
  zipCode         String
  lat             Float?
  lng             Float?

  // Specialties (stored as array)
  specialties     String[]

  // Rating
  averageRating   Float     @default(0)
  reviewCount     Int       @default(0)

  // Trust signals — admin-reviewed verification (license, insurance, identity).
  // Dynamic badge surfaces "Verified · checked {verifiedAt}".
  verified        Boolean   @default(false)
  verifiedAt      DateTime?

  // Analytics
  profileViews    Int       @default(0)

  // Promoted listing
  isPromoted      Boolean   @default(false)
  promotedUntil   DateTime?
  stripeCustomerId String?
  stripeSubId      String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conversations   Conversation[]
  leads           Lead[]
  reviews         Review[]
  portfolio       PortfolioProject[]
  favoritedBy     Favorite[]
  appointments    Appointment[]
}

// A homeowner saving a contractor to revisit later ("My Projects" hub).
model Favorite {
  id         String   @id @default(cuid())
  userId     String
  businessId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
}

model Conversation {
  id          String    @id @default(cuid())
  clientId    String
  businessId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Read receipts — when each side last opened the conversation.
  // A message is "unread" for a participant if it was sent by the other
  // party after this timestamp (null = they've never opened it).
  clientLastReadAt   DateTime?
  businessLastReadAt DateTime?

  client      User      @relation("ClientConversations", fields: [clientId], references: [id])
  business    Business  @relation(fields: [businessId], references: [id])
  messages    Message[]
  lead        Lead?

  @@unique([clientId, businessId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Lead {
  id             String       @id @default(cuid())
  conversationId String       @unique
  businessId     String
  status         LeadStatus   @default(NEW)
  notes          String?
  estimatedValue Int?         // estimated job value in dollars, set by the business
  billed         Boolean      @default(false)
  billedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  conversation   Conversation @relation(fields: [conversationId], references: [id])
  business       Business     @relation(fields: [businessId], references: [id])
}

// An in-app activity-feed entry for a recipient. Written alongside every push
// (new lead, message, appointment request/update) so users have a durable
// "what happened while I was away" inbox, not just ephemeral notifications.
model Activity {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  title     String
  body      String
  data      Json?        // deep-link payload, e.g. { conversationId } or { appointmentId }
  readAt    DateTime?
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A homeowner requesting a time with a contractor. The business confirms or
// declines; either party can cancel. Status drives both sides' appointment lists.
model Appointment {
  id          String            @id @default(cuid())
  clientId    String
  businessId  String
  scheduledAt DateTime
  durationMin Int               @default(60)
  note        String?
  status      AppointmentStatus @default(REQUESTED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client      User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  business    Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([businessId])
}

model PortfolioProject {
  id          String   @id @default(cuid())
  businessId  String
  title       String
  description String?
  category    String?  // e.g. "Kitchen", "Bathroom"
  costMin     Int?     // project cost range, in dollars
  costMax     Int?
  durationWeeks Int?
  imageUrls   String[]
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Estimation {
  id          String   @id @default(cuid())
  userId      String
  imageUrls   String[]
  roomType    String?
  description String?
  result      Json
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  businessId  String
  authorName  String
  rating      Int
  body        String?
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}
